{
  "profile_name": "rhel-readonly",
  "executable_whitelist_regex": [
    "^dnf$",
    "^yum$",
    "^rpm$",
    "^systemctl$",
    "^service$",
    "^journalctl$",
    "^hostnamectl$",
    "^timedatectl$",
    "^cat$",
    "^uname$",
    "^hostname$",
    "^df$",
    "^free$",
    "^uptime$",
    "^id$",
    "^whoami$",
    "^sestatus$",
    "^getenforce$"
  ],
  "whitelist_regex": [
    "^dnf\\s+(repolist|check-update|info|list\\s+installed)(\\s+.*)?$",
    "^yum\\s+(repolist|check-update|info|list\\s+installed)(\\s+.*)?$",
    "^rpm\\s+(-qa)(\\s|$)",
    "^rpm\\s+(-qi|-qf)\\s+\\S+(\\s|$)",
    "^systemctl\\s+(status|show|is-active|is-enabled|list-units|list-unit-files)(\\s|$)",
    "^service\\s+\\S+\\s+status(\\s|$)",
    "^journalctl(\\s+.*)?--no-pager(\\s|$)",
    "^hostnamectl\\s+status(\\s|$)",
    "^timedatectl\\s+status(\\s|$)",
    "^cat\\s+/etc/(os-release|redhat-release|centos-release|rocky-release|almalinux-release)(\\s|$)",
    "^uname(\\s|$)",
    "^hostname(\\s|$)",
    "^df(\\s|$)",
    "^free(\\s|$)",
    "^uptime(\\s|$)",
    "^id(\\s|$)",
    "^whoami(\\s|$)",
    "^sestatus(\\s|$)",
    "^getenforce(\\s|$)"
  ],
  "blacklist_regex": [
    ";",
    "&&",
    "\\|\\|",
    "\\|\\s*(bash|sh|zsh|fish|ksh)",
    ">",
    "`",
    "\\$\\(",
    "sudo\\s",
    "su\\s",
    "rm\\s",
    "user(add|del|mod)\\s",
    "group(add|del|mod)\\s"
  ]
}
