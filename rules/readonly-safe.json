{
  "profile_name": "readonly-safe",
  "executable_whitelist_regex": [
    "^ls$",
    "^cat$",
    "^df$",
    "^free$",
    "^uptime$",
    "^uname$",
    "^hostname$",
    "^date$",
    "^id$",
    "^whoami$",
    "^ps$",
    "^netstat$",
    "^ss$",
    "^ip$",
    "^lscpu$",
    "^lsmem$",
    "^lsblk$",
    "^lspci$",
    "^dmidecode$",
    "^systemctl$",
    "^journalctl$",
    "^top$",
    "^vmstat$",
    "^iostat$",
    "^dmesg$",
    "^env$",
    "^printenv$"
  ],
  "whitelist_regex": [
    "^ls(\\s|$)",
    "^cat\\s+/etc/(os-release|hostname|hosts|resolv\\.conf|fstab)",
    "^cat\\s+/proc/(cpuinfo|meminfo|version|loadavg|uptime)",
    "^df(\\s|$)",
    "^free(\\s|$)",
    "^uptime(\\s|$)",
    "^uname(\\s|$)",
    "^hostname(\\s|$)",
    "^date(\\s|$)",
    "^id(\\s|$)",
    "^whoami(\\s|$)",
    "^ps\\s+(aux|ax|ef)",
    "^netstat\\s+-",
    "^ss\\s+-",
    "^ip\\s+(addr|route|link|neigh)",
    "^lscpu(\\s|$)",
    "^lsmem(\\s|$)",
    "^lsblk(\\s|$)",
    "^lspci(\\s|$)",
    "^dmidecode(\\s|$)",
    "^systemctl\\s+(status|list-units|list-services)",
    "^journalctl(\\s|$)",
    "^top\\s+-b\\s+-n\\s+1",
    "^vmstat(\\s|$)",
    "^iostat(\\s|$)",
    "^dmesg(\\s|$)",
    "^env(\\s|$)",
    "^printenv(\\s|$)"
  ],
  "blacklist_regex": [
    "^journalctl(\\s+.*)?\\s(-f|--follow|--rotate|--vacuum-(time|size|files)(=\\S+)?|--flush|--relinquish-var|--smart-relinquish-var|--setup-keys)(\\s|$)",
    "rm\\s",
    "rmdir\\s",
    "mkfs",
    "dd\\s",
    "shred",
    "wipefs",
    "fdisk",
    "parted",
    "gdisk",
    "format",
    ";",
    "&&",
    "\\|\\|",
    "\\|\\s*(bash|sh|zsh|fish|ksh)",
    ">",
    "`",
    "\\$\\(",
    "chmod",
    "chown",
    "chgrp",
    "sudo",
    "su\\s",
    "passwd",
    "useradd",
    "userdel",
    "usermod",
    "groupadd",
    "curl",
    "wget",
    "fetch",
    "scp",
    "rsync",
    "python",
    "perl",
    "ruby",
    "php",
    "node",
    "nc\\s",
    "ncat",
    "socat",
    "mkfifo",
    "mknod",
    "exec\\s",
    "eval\\s",
    "source\\s",
    "\\.\\s",
    "base64\\s+-d"
  ]
}
