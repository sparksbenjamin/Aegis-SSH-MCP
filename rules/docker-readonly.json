{
  "profile_name": "docker-readonly",
  "executable_whitelist_regex": [
    "^docker$",
    "^systemctl$",
    "^journalctl$",
    "^df$",
    "^free$",
    "^uptime$",
    "^uname$",
    "^hostname$",
    "^date$",
    "^ls$",
    "^cat$",
    "^top$"
  ],
  "whitelist_regex": [
    "^docker\\s+(ps|images|stats|logs|inspect|info|version|network\\s+ls|volume\\s+ls)",
    "^docker\\s+compose\\s+(ps|logs|config)",
    "^systemctl\\s+(status|is-active|is-enabled)\\s+",
    "^journalctl\\s+",
    "^df\\b",
    "^free\\b",
    "^uptime\\b",
    "^uname\\b",
    "^hostname\\b",
    "^date\\b",
    "^ls\\s+",
    "^cat\\s+/var/log/",
    "^top\\s+-b\\s+-n\\s+1"
  ],
  "blacklist_regex": [
    "rm\\s",
    "rmdir\\s",
    "mkfs",
    "dd\\s",
    "shred\\s",
    "wipefs",
    ";",
    "&&",
    "\\|\\|",
    "\\|\\s*bash",
    "\\|\\s*sh",
    ">\\s*\\/",
    ">>",
    "`",
    "\\$\\(",
    "chmod\\s",
    "chown\\s",
    "sudo\\s",
    "su\\s",
    "passwd\\s",
    "useradd\\s",
    "userdel\\s",
    "curl\\s",
    "wget\\s",
    "python",
    "perl",
    "ruby",
    "php",
    "nc\\s",
    "ncat\\s",
    "socat\\s",
    "mkfifo",
    "mknod",
    "exec\\s"
  ]
}
