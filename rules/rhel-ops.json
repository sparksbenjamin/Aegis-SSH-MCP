{
  "profile_name": "rhel-ops",
  "executable_whitelist_regex": [
    "^dnf$",
    "^yum$",
    "^rpm$",
    "^systemctl$",
    "^service$",
    "^journalctl$",
    "^hostnamectl$",
    "^timedatectl$",
    "^ls$",
    "^cat$",
    "^uname$",
    "^hostname$",
    "^df$",
    "^free$",
    "^uptime$",
    "^id$",
    "^whoami$",
    "^sestatus$",
    "^getenforce$"
  ],
  "whitelist_regex": [
    "^dnf\\s+(repolist|check-update|info|list\\s+installed|makecache|install|remove|update|upgrade|reinstall)(\\s+.*)?$",
    "^yum\\s+(repolist|check-update|info|list\\s+installed|makecache|install|remove|update|upgrade|reinstall)(\\s+.*)?$",
    "^rpm\\s+(-qa)(\\s|$)",
    "^rpm\\s+(-qi|-qf)\\s+\\S+(\\s|$)",
    "^systemctl\\s+(status|show|is-active|is-enabled|list-units|list-unit-files|start|stop|restart|reload|try-restart|reload-or-restart|enable|disable)(\\s|$)",
    "^service\\s+\\S+\\s+(status|start|stop|restart|reload|force-reload)(\\s|$)",
    "^journalctl(\\s|$)",
    "^hostnamectl\\s+status(\\s|$)",
    "^timedatectl\\s+status(\\s|$)",
    "^ls(\\s|$)",
    "^cat\\s+/etc/(os-release|redhat-release|centos-release|rocky-release|almalinux-release)(\\s|$)",
    "^cat\\s+/var/log/\\S+(\\s|$)",
    "^uname(\\s|$)",
    "^hostname(\\s|$)",
    "^df(\\s|$)",
    "^free(\\s|$)",
    "^uptime(\\s|$)",
    "^id(\\s|$)",
    "^whoami(\\s|$)",
    "^sestatus(\\s|$)",
    "^getenforce(\\s|$)"
  ],
  "blacklist_regex": [
    "^journalctl(\\s+.*)?\\s(-f|--follow|--rotate|--vacuum-(time|size|files)(=\\S+)?|--flush|--relinquish-var|--smart-relinquish-var|--setup-keys)(\\s|$)",
    "^dnf\\s+(distro-sync|downgrade|autoremove|shell)(\\s|$)",
    "^yum\\s+(distro-sync|downgrade|autoremove|shell)(\\s|$)",
    "^systemctl\\s+(halt|poweroff|reboot|kexec|suspend|hibernate|hybrid-sleep|rescue|emergency|default|isolate|mask|unmask|preset|preset-all|link|switch-root|edit|set-default|set-property|revert|daemon-reexec)(\\s|$)",
    ";",
    "&&",
    "\\|\\|",
    "\\|\\s*(bash|sh|zsh|fish|ksh)",
    ">",
    "`",
    "\\$\\(",
    "sudo\\s",
    "su\\s",
    "rm\\s+-rf\\s+/",
    "curl\\s.*\\|.*sh",
    "wget\\s.*\\|.*sh"
  ]
}
