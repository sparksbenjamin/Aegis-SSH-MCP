{
  "profile_name": "ubuntu-ops",
  "executable_whitelist_regex": [
    "^apt$",
    "^apt-get$",
    "^apt-cache$",
    "^dpkg$",
    "^snap$",
    "^systemctl$",
    "^service$",
    "^journalctl$",
    "^hostnamectl$",
    "^timedatectl$",
    "^lsb_release$",
    "^ls$",
    "^cat$",
    "^uname$",
    "^hostname$",
    "^df$",
    "^free$",
    "^uptime$",
    "^id$",
    "^whoami$"
  ],
  "arguments_blacklist_regex": [
    "(^|\\s)--allow-(unauthenticated|downgrades|change-held-packages|remove-essential)(\\s|$)"
  ],
  "whitelist_regex": [
    "^apt\\s+(list\\s+--installed|list\\s+--upgradable|show\\s+\\S+|update|upgrade|install|remove|purge|autoremove)(\\s+.*)?$",
    "^apt-get\\s+(update|upgrade|install|remove|purge|autoremove)(\\s+.*)?$",
    "^apt-cache\\s+(policy|show|search|madison)(\\s+.*)?$",
    "^dpkg\\s+(-l|--list)(\\s|$)",
    "^dpkg\\s+(-s|--status)\\s+\\S+(\\s|$)",
    "^snap\\s+(list|services|changes|version)(\\s|$)",
    "^snap\\s+(info|connections|logs|tasks)\\s+\\S+(\\s+.*)?$",
    "^snap\\s+(install|remove|refresh|start|stop|restart|enable|disable)\\s+\\S+(\\s+.*)?$",
    "^systemctl\\s+(status|show|is-active|is-enabled|list-units|list-unit-files|start|stop|restart|reload|try-restart|reload-or-restart|enable|disable)(\\s|$)",
    "^service\\s+\\S+\\s+(status|start|stop|restart|reload|force-reload)(\\s|$)",
    "^journalctl(\\s|$)",
    "^hostnamectl\\s+status(\\s|$)",
    "^timedatectl\\s+status(\\s|$)",
    "^lsb_release\\s+-a(\\s|$)",
    "^ls(\\s|$)",
    "^cat\\s+/etc/(os-release|debian_version|lsb-release|issue|issue.net)(\\s|$)",
    "^cat\\s+/var/log/\\S+(\\s|$)",
    "^uname(\\s|$)",
    "^hostname(\\s|$)",
    "^df(\\s|$)",
    "^free(\\s|$)",
    "^uptime(\\s|$)",
    "^id(\\s|$)",
    "^whoami(\\s|$)"
  ],
  "blacklist_regex": [
    "^journalctl(\\s+.*)?\\s(-f|--follow|--rotate|--vacuum-(time|size|files)(=\\S+)?|--flush|--relinquish-var|--smart-relinquish-var|--setup-keys)(\\s|$)",
    "^apt(-get)?\\s+(full-upgrade|dist-upgrade)(\\s|$)",
    "^systemctl\\s+(halt|poweroff|reboot|kexec|suspend|hibernate|hybrid-sleep|rescue|emergency|default|isolate|mask|unmask|preset|preset-all|link|switch-root|edit|set-default|set-property|revert|daemon-reexec)(\\s|$)",
    ";",
    "&&",
    "\\|\\|",
    "\\|\\s*(bash|sh|zsh|fish|ksh)",
    ">",
    "`",
    "\\$\\(",
    "sudo\\s",
    "su\\s",
    "rm\\s+-rf\\s+/",
    "curl\\s.*\\|.*sh",
    "wget\\s.*\\|.*sh"
  ]
}
