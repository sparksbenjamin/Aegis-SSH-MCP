{
  "profile_name": "proxmox-readonly",
  "executable_whitelist_regex": [
    "^pveversion$",
    "^pvesh$",
    "^pvecm$",
    "^qm$",
    "^pct$",
    "^pvesm$",
    "^systemctl$",
    "^journalctl$",
    "^hostnamectl$",
    "^timedatectl$",
    "^ls$",
    "^cat$",
    "^uname$",
    "^hostname$",
    "^df$",
    "^free$",
    "^uptime$",
    "^id$",
    "^whoami$"
  ],
  "whitelist_regex": [
    "^pveversion(\\s|$)",
    "^pvesh\\s+(get|ls)\\s+/[A-Za-z0-9._:/-]+(\\s+.*)?$",
    "^pvecm\\s+(status|nodes)(\\s|$)",
    "^qm\\s+list(\\s|$)",
    "^qm\\s+(status|config)\\s+\\d+(\\s+.*)?$",
    "^pct\\s+list(\\s|$)",
    "^pct\\s+(status|config)\\s+\\d+(\\s+.*)?$",
    "^pvesm\\s+status(\\s|$)",
    "^pvesm\\s+list\\s+\\S+(\\s+.*)?$",
    "^systemctl\\s+(status|show|is-active|is-enabled|list-units|list-unit-files)(\\s|$)",
    "^journalctl(\\s|$)",
    "^hostnamectl\\s+status(\\s|$)",
    "^timedatectl\\s+status(\\s|$)",
    "^ls(\\s|$)",
    "^cat\\s+/etc/(os-release|debian_version|issue|issue.net)(\\s|$)",
    "^cat\\s+/etc/pve/corosync\\.conf(\\s|$)",
    "^cat\\s+/var/log/\\S+(\\s|$)",
    "^uname(\\s|$)",
    "^hostname(\\s|$)",
    "^df(\\s|$)",
    "^free(\\s|$)",
    "^uptime(\\s|$)",
    "^id(\\s|$)",
    "^whoami(\\s|$)"
  ],
  "blacklist_regex": [
    "^journalctl(\\s+.*)?\\s(-f|--follow|--rotate|--vacuum-(time|size|files)(=\\S+)?|--flush|--relinquish-var|--smart-relinquish-var|--setup-keys)(\\s|$)",
    "^pvesh\\s+(set|create|delete)(\\s|$)",
    "^pvecm\\s+(add|delnode|expected|updatecerts)(\\s|$)",
    "^qm\\s+(start|stop|shutdown|reboot|reset|suspend|resume|destroy|clone|migrate|move-disk|importdisk|disk|set|template|rollback|restore|unlink)(\\s|$)",
    "^pct\\s+(start|stop|shutdown|reboot|suspend|resume|destroy|clone|migrate|move-volume|set|restore|push|pull)(\\s|$)",
    "^pvesm\\s+(add|alloc|create|free|remove|set)(\\s|$)",
    "^systemctl\\s+(start|stop|restart|reload|try-restart|reload-or-restart|enable|disable|halt|poweroff|reboot|kexec|suspend|hibernate|hybrid-sleep|rescue|emergency|default|isolate|mask|unmask|preset|preset-all|link|switch-root|edit|set-default|set-property|revert|daemon-reexec)(\\s|$)",
    ";",
    "&&",
    "\\|\\|",
    "\\|\\s*(bash|sh|zsh|fish|ksh)",
    ">",
    "`",
    "\\$\\(",
    "sudo\\s",
    "su\\s",
    "rm\\s+-rf\\s+/",
    "curl\\s.*\\|.*sh",
    "wget\\s.*\\|.*sh"
  ]
}
