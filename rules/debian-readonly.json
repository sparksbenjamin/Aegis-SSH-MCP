{
  "profile_name": "debian-readonly",
  "executable_whitelist_regex": [
    "^apt$",
    "^apt-cache$",
    "^dpkg$",
    "^systemctl$",
    "^service$",
    "^journalctl$",
    "^hostnamectl$",
    "^timedatectl$",
    "^lsb_release$",
    "^ls$",
    "^cat$",
    "^uname$",
    "^hostname$",
    "^df$",
    "^free$",
    "^uptime$",
    "^id$",
    "^whoami$"
  ],
  "whitelist_regex": [
    "^apt\\s+(list\\s+--installed|list\\s+--upgradable|show\\s+\\S+)(\\s|$)",
    "^apt-cache\\s+(policy|show|search|madison)(\\s+.*)?$",
    "^dpkg\\s+(-l|--list)(\\s|$)",
    "^dpkg\\s+(-s|--status)\\s+\\S+(\\s|$)",
    "^systemctl\\s+(status|show|is-active|is-enabled|list-units|list-unit-files)(\\s|$)",
    "^service\\s+\\S+\\s+status(\\s|$)",
    "^journalctl(\\s|$)",
    "^hostnamectl\\s+status(\\s|$)",
    "^timedatectl\\s+status(\\s|$)",
    "^lsb_release\\s+-a(\\s|$)",
    "^ls(\\s|$)",
    "^cat\\s+/etc/(os-release|debian_version|issue|issue.net)(\\s|$)",
    "^cat\\s+/var/log/\\S+(\\s|$)",
    "^uname(\\s|$)",
    "^hostname(\\s|$)",
    "^df(\\s|$)",
    "^free(\\s|$)",
    "^uptime(\\s|$)",
    "^id(\\s|$)",
    "^whoami(\\s|$)"
  ],
  "blacklist_regex": [
    "^journalctl(\\s+.*)?\\s(-f|--follow|--rotate|--vacuum-(time|size|files)(=\\S+)?|--flush|--relinquish-var|--smart-relinquish-var|--setup-keys)(\\s|$)",
    ";",
    "&&",
    "\\|\\|",
    "\\|\\s*(bash|sh|zsh|fish|ksh)",
    ">",
    "`",
    "\\$\\(",
    "sudo\\s",
    "su\\s",
    "rm\\s",
    "user(add|del|mod)\\s",
    "group(add|del|mod)\\s"
  ]
}
